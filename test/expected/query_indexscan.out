-- pg_orca indexscan regression tests
-- Ported from Greenplum testrepo/query/indexscan
LOAD 'pg_orca';
SET pg_orca.enable_orca = on;
SET client_min_messages = warning;
-- bfv_mpp23383_nonpartitioned_setup.sql
create table mpp23383(a int, b varchar(20));
insert into mpp23383 select g,g from generate_series(1,1000) g;
create index mpp23383_b on mpp23383(b);
-- bfv_mpp23383_nonpartitioned.sql
EXPLAIN select * from mpp23383 where b='1';
                                  QUERY PLAN                                  
------------------------------------------------------------------------------
 Index Scan using mpp23383_b on mpp23383  (cost=0.00..0.19 rows=400 width=12)
   Index Cond: ((b)::text = '1'::text)
 Optimizer: pg_orca
(3 rows)

select * from mpp23383 where b='1';
 a | b 
---+---
 1 | 1
(1 row)

EXPLAIN select * from mpp23383 where '1'=b;
                                  QUERY PLAN                                  
------------------------------------------------------------------------------
 Index Scan using mpp23383_b on mpp23383  (cost=0.00..0.19 rows=400 width=12)
   Index Cond: ((b)::text = '1'::text)
 Optimizer: pg_orca
(3 rows)

select * from mpp23383 where '1'=b;
 a | b 
---+---
 1 | 1
(1 row)

EXPLAIN select * from mpp23383 where '2'> b order by a limit 10;
                                        QUERY PLAN                                        
------------------------------------------------------------------------------------------
 Limit  (cost=0.00..0.43 rows=10 width=12)
   ->  Sort  (cost=0.00..0.43 rows=400 width=12)
         Sort Key: a
         ->  Index Scan using mpp23383_b on mpp23383  (cost=0.00..0.19 rows=400 width=12)
               Index Cond: ((b)::text < '2'::text)
 Optimizer: pg_orca
(6 rows)

select * from mpp23383 where '2'> b order by a limit 10;
 a  | b  
----+----
  1 | 1
 10 | 10
 11 | 11
 12 | 12
 13 | 13
 14 | 14
 15 | 15
 16 | 16
 17 | 17
 18 | 18
(10 rows)

EXPLAIN select * from mpp23383 where b between '1' and '2' order by a limit 10;
                                        QUERY PLAN                                        
------------------------------------------------------------------------------------------
 Limit  (cost=0.00..0.43 rows=10 width=12)
   ->  Sort  (cost=0.00..0.43 rows=400 width=12)
         Sort Key: a
         ->  Index Scan using mpp23383_b on mpp23383  (cost=0.00..0.19 rows=400 width=12)
               Index Cond: (((b)::text >= '1'::text) AND ((b)::text <= '2'::text))
 Optimizer: pg_orca
(6 rows)

select * from mpp23383 where b between '1' and '2' order by a limit 10;
 a  | b  
----+----
  1 | 1
  2 | 2
 10 | 10
 11 | 11
 12 | 12
 13 | 13
 14 | 14
 15 | 15
 16 | 16
 17 | 17
(10 rows)

-- predicates on both index and non-index key
EXPLAIN select * from mpp23383 where b='1' and a='1';
                                  QUERY PLAN                                  
------------------------------------------------------------------------------
 Index Scan using mpp23383_b on mpp23383  (cost=0.00..0.21 rows=400 width=12)
   Index Cond: ((b)::text = '1'::text)
   Filter: (a = 1)
 Optimizer: pg_orca
(4 rows)

select * from mpp23383 where b='1' and a='1';
 a | b 
---+---
 1 | 1
(1 row)

--negative tests: no index scan plan possible, fall back to planner
EXPLAIN select * from mpp23383 where b::int='1';
                         QUERY PLAN                          
-------------------------------------------------------------
 Seq Scan on mpp23383  (cost=0.00..431.07 rows=400 width=12)
   Filter: ((b)::integer = 1)
 Optimizer: pg_orca
(3 rows)

-- bfv_mpp23383_partitioned.50.sql
-- @skip MPP-21069, MPP-24883 skip test due to Unexpected internal error
-- setup
-- start_ignore
create table mpp23383_partitioned(a int, b varchar(20), c varchar(20), d varchar(20))
partition by range(a);
create table mpp23383_partitioned_p1 partition of mpp23383_partitioned
  for values from (1) to (500);
create table mpp23383_partitioned_p2 partition of mpp23383_partitioned
  for values from (500) to (1001);
insert into mpp23383_partitioned select g,g,g,g from generate_series(1,1000) g;
create index idx_b on mpp23383_partitioned(b);
-- heterogenous indexes
create index idx_c on mpp23383_partitioned_p1(c);
create index idx_cd on mpp23383_partitioned_p2(c,d);
-- end_ignore
explain select * from mpp23383_partitioned where b='1';
                                                  QUERY PLAN                                                  
--------------------------------------------------------------------------------------------------------------
 Append  (cost=4.29..14.87 rows=5 width=178)
   ->  Bitmap Heap Scan on mpp23383_partitioned_p1 mpp23383_partitioned_1  (cost=4.29..7.41 rows=2 width=178)
         Recheck Cond: ((b)::text = '1'::text)
         ->  Bitmap Index Scan on mpp23383_partitioned_p1_b_idx  (cost=0.00..4.29 rows=2 width=0)
               Index Cond: ((b)::text = '1'::text)
   ->  Bitmap Heap Scan on mpp23383_partitioned_p2 mpp23383_partitioned_2  (cost=4.30..7.43 rows=3 width=178)
         Recheck Cond: ((b)::text = '1'::text)
         ->  Bitmap Index Scan on mpp23383_partitioned_p2_b_idx  (cost=0.00..4.29 rows=3 width=0)
               Index Cond: ((b)::text = '1'::text)
(9 rows)

select * from mpp23383_partitioned where b='1';
 a | b | c | d 
---+---+---+---
 1 | 1 | 1 | 1
(1 row)

explain select * from mpp23383_partitioned where '1'=b;
                                                  QUERY PLAN                                                  
--------------------------------------------------------------------------------------------------------------
 Append  (cost=4.29..14.87 rows=5 width=178)
   ->  Bitmap Heap Scan on mpp23383_partitioned_p1 mpp23383_partitioned_1  (cost=4.29..7.41 rows=2 width=178)
         Recheck Cond: ('1'::text = (b)::text)
         ->  Bitmap Index Scan on mpp23383_partitioned_p1_b_idx  (cost=0.00..4.29 rows=2 width=0)
               Index Cond: ((b)::text = '1'::text)
   ->  Bitmap Heap Scan on mpp23383_partitioned_p2 mpp23383_partitioned_2  (cost=4.30..7.43 rows=3 width=178)
         Recheck Cond: ('1'::text = (b)::text)
         ->  Bitmap Index Scan on mpp23383_partitioned_p2_b_idx  (cost=0.00..4.29 rows=3 width=0)
