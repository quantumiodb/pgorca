-- ===================================================================
-- Test 4: IN list b IN (5, 6, 14, 23) -- 3 partitions ([1,11), [11,21), [21,31))
-- ===================================================================
EXPLAIN (costs off) SELECT * FROM foo WHERE b IN (5, 6, 14, 23);
                   QUERY PLAN                   
------------------------------------------------
 Custom Scan (DynamicTableScan)
   Filter: (b = ANY ('{5,6,14,23}'::integer[]))
   Root Table: foo
   Partitions Selected: 3
 Optimizer: pg_orca
(5 rows)

SELECT * FROM foo WHERE b IN (5, 6, 14, 23) ORDER BY a, b, c;
 a | b  | c 
---+----+---
 5 |  5 | 5
   |  6 | 6
   | 14 |  
   | 23 |  
(4 rows)

