-- ===================================================================
-- Test 6: Out-of-range b = 150 -- 0 partitions (empty result)
-- ===================================================================
EXPLAIN (costs off) SELECT * FROM foo WHERE b = 150;
        QUERY PLAN        
--------------------------
 Result
   One-Time Filter: false
 Optimizer: pg_orca
(3 rows)

SELECT * FROM foo WHERE b = 150 ORDER BY a, b, c;
 a | b | c 
---+---+---
(0 rows)

-- ===================================================================
-- Test 7: Non-constant predicate b = a*5 -- cannot prune statically, all 10 partitions
-- ===================================================================
EXPLAIN (costs off) SELECT * FROM foo WHERE b = a*5;
           QUERY PLAN           
--------------------------------
 Custom Scan (DynamicTableScan)
   Filter: (b = (a * 5))
   Root Table: foo
   Partitions Selected: 10
 Optimizer: pg_orca
(5 rows)

SELECT * FROM foo WHERE b = a*5 ORDER BY a, b, c;
 a | b | c 
---+---+---
(0 rows)

-- ===================================================================
-- Cleanup
-- ===================================================================
DROP TABLE foo CASCADE;
