-- Subqueries (IN / EXISTS)
EXPLAIN (COSTS OFF, VERBOSE) SELECT * FROM customer WHERE c_custkey IN (SELECT c_custkey FROM nation);
                                                                                      QUERY PLAN                                                                                      
--------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
 Nested Loop
   Output: customer.c_custkey, customer.c_name, customer.c_address, customer.c_nationkey, customer.c_phone, customer.c_acctbal, customer.c_mktsegment, customer.c_comment
   Join Filter: ((count(*)) > '0'::bigint)
   ->  Aggregate
         Output: count(*)
         ->  Seq Scan on public.nation
   ->  Materialize
         Output: customer.c_custkey, customer.c_name, customer.c_address, customer.c_nationkey, customer.c_phone, customer.c_acctbal, customer.c_mktsegment, customer.c_comment
         ->  Seq Scan on public.customer
               Output: customer.c_custkey, customer.c_name, customer.c_address, customer.c_nationkey, customer.c_phone, customer.c_acctbal, customer.c_mktsegment, customer.c_comment
               Filter: (customer.c_custkey = customer.c_custkey)
 Optimizer: pg_orca
(12 rows)

EXPLAIN (COSTS OFF, VERBOSE) SELECT * FROM customer x WHERE c_custkey IN (SELECT x.c_nationkey FROM nation);
                                                          QUERY PLAN                                                          
------------------------------------------------------------------------------------------------------------------------------
 Nested Loop
   Output: x.c_custkey, x.c_name, x.c_address, x.c_nationkey, x.c_phone, x.c_acctbal, x.c_mktsegment, x.c_comment
   Join Filter: ((count(*)) > '0'::bigint)
   ->  Aggregate
         Output: count(*)
         ->  Seq Scan on public.nation
   ->  Materialize
         Output: x.c_custkey, x.c_name, x.c_address, x.c_nationkey, x.c_phone, x.c_acctbal, x.c_mktsegment, x.c_comment
         ->  Seq Scan on public.customer x
               Output: x.c_custkey, x.c_name, x.c_address, x.c_nationkey, x.c_phone, x.c_acctbal, x.c_mktsegment, x.c_comment
               Filter: (x.c_custkey = x.c_nationkey)
 Optimizer: pg_orca
(12 rows)

-- Self-join (non-equi)
EXPLAIN (COSTS OFF, VERBOSE) SELECT * FROM customer a JOIN customer b ON a.c_custkey != b.c_custkey;
                                                                                                        QUERY PLAN                                                                                                        
--------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
 Nested Loop
