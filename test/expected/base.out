-- JOINs
EXPLAIN SELECT * FROM orders JOIN nation ON orders.o_custkey = nation.n_regionkey;
                              QUERY PLAN                               
-----------------------------------------------------------------------
 Hash Join  (cost=0.00..862.97 rows=810 width=80)
   Hash Cond: (orders.o_custkey = nation.n_regionkey)
