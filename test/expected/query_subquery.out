-- @description MPP-22601: Prohibit plans with Motions above outer references
select (select a from foo inner1 where inner1.a=outer1.a  union select b from foo inner2 where inner2.b=outer1.b) from foo outer1;
 a 
---
 1
 2
(2 rows)

